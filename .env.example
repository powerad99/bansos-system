# ===== App =====
APP_NAME="Bansos Distribution System"
APP_ENV=development
DEBUG=true

# ===== Database =====
DATABASE_URL=postgresql+psycopg2://bansos:bansos123@localhost:5432/bansos_db

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Security =====
SECRET_KEY=ganti-dengan-string-acak-panjang-min-32-karakter-please
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ===== QR =====
QR_SECRET=qr-secret-untuk-signing-payload

# ===== OCR =====
# tesseract | paddle
OCR_ENGINE=tesseract
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=ind+eng

# ===== Fraud Threshold =====
FUZZY_NAMA_THRESHOLD=90
FUZZY_ALAMAT_THRESHOLD=85

# ===== Priority =====
PRIORITY_HIGH_THRESHOLD=0.75
PRIORITY_MEDIUM_THRESHOLD=0.45

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
